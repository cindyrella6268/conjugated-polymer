#input for on-site energies
units                  real
atom_style             full

pair_style             lj/cut/coul/long 6.0
bond_style             none
angle_style            none
dihedral_style         none
improper_style         none
#kspace_style           pppm 1.0e-4

#read data
#read_data              eq3_last_equil.data
read_data              REPLACE_DATAFILE

kspace_style           pppm 1.0e-6
#loop over monomers (generated by python)
group                  MONOMER id REPLACE_IDS

#separate selected monomer from the rest
group                  REST subtract all MONOMER

#compute electrostatic interactions
compute                Eelec MONOMER group/group REST pair yes kspace yes boundary no molecule off

#kcal to eV
variable               e_eV equal c_Eelec*0.04336
run                    0

print                  "E_MONOMER = ${e_eV} eV"
